# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://zqcjnfcwxkeapwzhifsy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini AI (for quiz generator)
# Preferred key name. Also accepted: GOOGLE_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY,
# GOOGLE_GEMINI_API_KEY, GENERATIVE_LANGUAGE_API_KEY (or integration_config GEMINI row).
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_PRIMARY_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Biometric API Key (for attendance system)
BIOMETRIC_API_KEY=your_biometric_api_key_here
